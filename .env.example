# oci-admin-bot — example environment file.
# Copy to secrets.env, fill in real values, and `source secrets.env`.
# Never commit secrets.env.

# ---------- Slack ----------
export OCI_ADMIN_SLACK_BOT_TOKEN=xoxb-...
export OCI_ADMIN_SLACK_CHANNEL=#oci-admin
export OCI_ADMIN_SLACK_CHANNEL_ID=C0XXXXXXXXX

# ---------- OCI ----------
# OCI CLI itself reads ~/.oci/config; these are extra app-level vars.
export OCI_ADMIN_OCI_REGION=us-ashburn-1

# Fusion environment OCIDs (set whichever you actually have).
export PROD_OCID=ocid1.fusionenvironment.oc1.iad..xxxxx
export DEV1_OCID=ocid1.fusionenvironment.oc1.iad..xxxxx
export DEV2_OCID=ocid1.fusionenvironment.oc1.iad..xxxxx
export DEV3_OCID=ocid1.fusionenvironment.oc1.iad..xxxxx
export DEV4_OCID=ocid1.fusionenvironment.oc1.iad..xxxxx
export TEST_OCID=ocid1.fusionenvironment.oc1.iad..xxxxx

# Identity Domains (IDCS) endpoint, used by oci_access_review.py.
export OCI_ADMIN_IDCS_ENDPOINT=https://idcs-XXXXX.identity.oraclecloud.com

# OCI Object Storage namespace + bucket where the bot stores its state files.
export OCI_ADMIN_OCI_NAMESPACE=your-oci-namespace
export OCI_ADMIN_OCI_BUCKET=oci-admin-state

# ---------- Jira (Atlassian Cloud) ----------
export OCI_ADMIN_JIRA_EMAIL=you@example.com
export OCI_ADMIN_JIRA_TOKEN=ATATT3x...
export OCI_ADMIN_JIRA_BASE=https://your-org.atlassian.net
export OCI_ADMIN_JIRA_PROJECT=OPS
export OCI_ADMIN_JIRA_COMPONENT=12345        # Jira component ID
export OCI_ADMIN_JIRA_SPRINT=                # optional sprint ID
export OCI_ADMIN_ASSIGNEE_ACCOUNT_ID=        # Jira account ID for default assignee
export OCI_ADMIN_ASSIGNEE_EMAIL=             # email of default assignee
export OCI_ADMIN_RELEASE_ASSIGNEE_ID=        # Jira account ID for quarterly release assignee

# ---------- parse_and_notify.py specific ----------
export OCI_ADMIN_SAAS_USAGE_DIR=/path/to/local/saas-usage
export JIRA_ASSIGNEE_ERP=
export JIRA_ASSIGNEE_EPBCS=
export JIRA_ASSIGNEE_FCCS_EDM=
export SLACK_USER_ERP=user-erp@example.com
export SLACK_USER_EPBCS=user-epbcs@example.com
export SLACK_USER_FCCS_EDM=user-fccs-edm@example.com
